{
  "$schema": "https://raw.githubusercontent.com/samsarahq/functions-examples/refs/heads/main/.schemas/importMetadata.schema.json",
  "name": "just-schedule",
  "description": "Demonstrates a scheduled function that fetches vehicle count from the Samsara API hourly.",
  "secretsKeys": ["SAMSARA_API_KEY"],
  "isSchedulingEnabled": true,
  "schedule": {
    "entries": [
      {
        "timeSinceMidnightMs": 57600000,
        "daysOfWeek": [false, true, true, true, true, true, false]
      },
      {
        "timeSinceMidnightMs": 50400000,
        "daysOfWeek": [true, false, false, false, false, false, true]
      }
    ]
  },
  "handler": "function.main"
}
